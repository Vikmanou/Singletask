{
	"name": "burnt-tomato",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"main": "electron/main.cjs",
	"icon": "public/logo.ico",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"lint": "eslint .",
		"preview": "vite preview",
		"electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:8080 && cross-env ELECTRON_ENV=development electron .\"",
		"electron:preview": "vite build && electron .",
		"electron:build": "vite build && electron-builder",
		"electron:build:packager": "vite build && electron-packager . \"Burnt Tomato\" --platform=win32 --arch=x64 --out=release --overwrite --icon=public/logo.ico --ignore=node_modules --ignore=src --ignore=public --ignore=release --ignore=electron/preload.cjs"
	},
	"build": {
		"appId": "com.burnttomato.app",
		"productName": "Burnt Tomato",
		"icon": "public/logo.png",
		"directories": {
			"output": "release"
		},
		"files": [
			"dist/**",
			"electron/**",
			"package.json"
		],
		"win": {
			"target": "nsis"
		},
		"mac": {
			"target": "dmg"
		},
		"linux": {
			"target": "AppImage"
		}
	},
	"dependencies": {
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@electron/packager": "^19.1.0",
		"@eslint/js": "^9.39.4",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"concurrently": "^9.2.1",
		"cross-env": "^10.1.0",
		"electron": "^41.1.1",
		"electron-builder": "^26.8.1",
		"eslint": "^9.39.4",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.4.0",
		"vite": "^8.0.1",
		"wait-on": "^9.0.4"
	}
}